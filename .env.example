# Image2 MCP — Environment Configuration
# Copy to ~/.claude/.env and fill in your API key.
#
#   cp .env.example ~/.claude/.env
#
# For one-click setup, run:
#   bash scripts/setup.sh

# Required: Your company API key
MAGENE_API_KEY=sk-your-api-key-here

# Optional: API endpoint (default shown below)
# MAGENE_API_BASE_URL=http://localhost:11636/api/v1/images/generations

# Optional: Default output directory for generated images
# IMAGE2_OUTPUT_DIR=~/Pictures/image2-output

# Optional: Override the model name
# IMAGE2_MODEL=openai/gpt-image-2
